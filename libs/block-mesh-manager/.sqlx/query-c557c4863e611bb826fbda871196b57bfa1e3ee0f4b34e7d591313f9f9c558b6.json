  "db_name": "PostgreSQL",
  "query": "\nWITH input_data(user_id, name) AS (\n  VALUES\n    ($1::uuid, 'Uptime'),\n    ($1::uuid, 'InteractiveExt'),\n    ($1::uuid, 'Wootz'),\n    ($1::uuid, 'Download'),\n    ($1::uuid, 'Upload'),\n    ($1::uuid, 'Latency'),\n    ($1::uuid, 'Tasks')\n)\nSELECT a.id, a.created_at, a.user_id, a.name, a.value, a.updated_at\nFROM aggregates a\nJOIN input_data i USING (user_id, name)\n",
